# =========================
config/secrets.json
config/*.key
config/*.pem

# =========================
# 🖼 Uploads (user files - IMPORTANT)
# =========================
uploads/
temp/

# =========================
# 📄 PDF FILE HANDLING (IMPORTANT RULE)
# =========================

# ❌ DO NOT TRACK user uploaded PDFs
uploads/**/*.pdf

# ✅ ALLOW project/documentation PDFs (optional folder)
!docs/
!docs/**/*.pdf

